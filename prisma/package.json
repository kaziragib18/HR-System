{
  "name": "@hr-system/prisma",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "migrate": "dotenv -e ../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../.env -- prisma migrate deploy",
    "generate": "prisma generate",
    "studio": "dotenv -e ../.env -- prisma studio",
    "seed": "dotenv -e ../.env tsx src/seed.ts",
    "seed:demo": "dotenv -e ../.env tsx src/seed-demo.ts",
    "reset": "dotenv -e ../.env -- prisma migrate reset"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@hr-system/types": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "dotenv-cli": "^11.0.0",
    "prisma": "^5.14.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0"
  }
}
